# SunPlus Power India Backend configuration template

# Core API configs
PROJECT_NAME="SunPlus Power India Platform"
DEBUG=True
API_PORT=8000
API_HOST="0.0.0.0"

# CORS configuration (comma separated list of allowed origins)
ALLOWED_ORIGINS="http://localhost,http://localhost:80,http://localhost:3000,http://127.0.0.1"

# Database configs
# Use PostgreSQL inside Docker or local DB.
DATABASE_URL="postgresql://postgres:sunplus_secure_pass@db:5432/sunplus_power"

# Security configs
# Generate a secure key e.g. using openssl rand -hex 32
JWT_SECRET="d11ca7c6f09e66cd22026ae838234be19fde87cb9e47f2e185cde643c7b3be64"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Rate Limiting (e.g. 5/minute for public POST, 60/minute for GET)
RATE_LIMIT_PUBLIC_POST="5/minute"
RATE_LIMIT_PUBLIC_GET="60/minute"

# SMTP config
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="smtp@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="noreply@sunpluspower.in"

# Notification recipients
NOTIFICATION_EMAIL_SALES="sales@sunpluspower.in"
NOTIFICATION_EMAIL_ACCOUNTS="accounts@sunpluspower.in"
NOTIFICATION_EMAIL_SUPPORT="support@sunpluspower.in"

# Upload constraints
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_EXTENSIONS="jpg,jpeg,png"
ALLOWED_DOCUMENT_EXTENSIONS="pdf,doc,docx"
UPLOAD_DIR="./uploads"
